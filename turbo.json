{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env",
    ".env.local"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DISCORD_BUG_REPORT_WEBHOOK_URL",
        "DISCORD_FEATURE_IDEAS_WEBHOOK_URL",
        "GITHUB_TOKEN",
        "GITHUB_WEBHOOK_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_DOWNLOAD_URL",
        "NEXT_PUBLIC_MAX_PRODUCT_ID",
        "NEXT_PUBLIC_OPENPANEL_API_URL",
        "NEXT_PUBLIC_OPENPANEL_CLIENT_ID",
        "NEXT_PUBLIC_PLUS_PRODUCT_ID",
        "NEXT_PUBLIC_PRO_PRODUCT_ID",
        "NEXT_PUBLIC_TEAM_PRODUCT_ID",
        "OPENPANEL_CLIENT_ID",
        "OPENPANEL_SECRET_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_ORGANIZATION_ID",
        "POLAR_PRODUCT_ID_MAX",
        "POLAR_PRODUCT_ID_PLUS",
        "POLAR_PRODUCT_ID_PRO",
        "POLAR_PRODUCT_ID_TEAM",
        "POLAR_WEBHOOK_SECRET",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "generated/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
